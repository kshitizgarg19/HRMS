# ── NexusHR environment ──────────────────────────────────────────────
# Local dev needs NOTHING — it falls back to a local SQLite file at data/nexus-hrms.db.
# For production (Vercel + Turso), set all three of these in the Vercel dashboard.

# Turso database URL (looks like: libsql://your-db-name-yourorg.turso.io)
DATABASE_URL=

# Turso auth token (from: turso db tokens create <db>)
DATABASE_AUTH_TOKEN=

# Secret used to sign login cookies. Generate one with:  openssl rand -base64 32
NEXUS_JWT_SECRET=
